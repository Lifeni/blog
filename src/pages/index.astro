---
import Main from '@components/layout/Main.astro'
import ArticleCard from '@components/notebook/article/ArticleCard.astro'
import Layout from '@components/notebook/Layout.astro'
import { getCollection } from 'astro:content'

const articles = await getCollection('文章')
---

<Layout>
  <Main class:list={['p-4 sm:px-6 sm:py-8']}>
    <ul
      class:list={[
        'w-full max-w-148',
        'mx-auto my-0 p-0',
        'flex flex-col gap-4',
      ]}
    >
      {
        articles
          .map(article => article.data)
          .filter(
            article =>
              article.featured && (import.meta.env.DEV || !article.draft),
          )
          .sort(
            (a, b) =>
              new Date(b.date.created).getTime() -
              new Date(a.date.created).getTime(),
          )
          .map(article => <ArticleCard article={article} />)
      }
    </ul>
  </Main>
</Layout>
