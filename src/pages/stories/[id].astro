---
import Main from '@components/layout/Main.astro'
import ArticleCard from '@components/notebook/article/ArticleCard.astro'
import ArticleMarkdown from '@components/notebook/article/ArticleMarkdown.astro'
import Layout from '@components/notebook/Layout.astro'
import { frontmatterFormat } from '@libs/utils'
import { Icon } from 'astro-icon/components'
import { getCollection, render } from 'astro:content'
import dayjs from 'dayjs'

export async function getStaticPaths() {
  const stories = await getCollection('专题')
  return stories
    .filter(story => import.meta.env.DEV || !story.data.draft)
    .map(story => ({
      params: { id: story.data.id },
      props: { story },
    }))
}

const { story } = Astro.props
const { Content, headings } = await render(story)

const articles = await getCollection('文章')
const archives = await getCollection('存档')

const storyArticles = articles
  .filter(article => story.data.articles?.includes(article.data.id))
  .map(article => ({ ...article.data, type: '文章' }))

const storyArchives = archives
  .filter(archive => story.data.articles?.includes(archive.data.name))
  .map(archive => ({ ...frontmatterFormat(archive.data), type: '存档' }))

const allArticles = [...storyArticles, ...storyArchives]
  .filter(article => import.meta.env.DEV || !article.draft)
  .sort((a, b) => dayjs(b.date.created).unix() - dayjs(a.date.created).unix())
---

<Layout name={story.data.name} description={story.data.description}>
  <Main class:list={['sm:px-6 sm:py-4']}>
    <ArticleMarkdown
      {...story.data}
      id={headings[0].slug}
      date={{
        created: story.data.date.created,
        updated:
          allArticles.length > 0
            ? allArticles[0].date.created
            : story.data.date.updated,
      }}
      cover={{
        path: story.data.cover?.path,
        description: story.data.cover?.description || '',
      }}
      content={Content}
      icon="ri:chat-thread-fill"
    />
    {
      storyArticles.length > 0 && (
        <section
          class:list={[
            'w-full max-w-156 sm:max-w-148',
            'mx-auto px-4 sm:px-0',
            'flex flex-col',
          ]}
        >
          <div
            class:list={[
              'flex flex-col justify-center items-center gap-1',
              'px-4 py-6',
              'text-sm text-center text-neutral-500 dark:text-neutral-400',
            ]}
          >
            <span class:list={['flex', 'whitespace-nowrap']}>
              包含 {allArticles.length} 篇文章
            </span>
            <Icon
              aria-hidden="true"
              name="ri:arrow-down-double-line"
              class:list={['w-4 h-4']}
            />
          </div>

          <ul class:list={['w-full', 'm-0 p-0', 'flex flex-col gap-4']}>
            {allArticles.map(article => (
              <ArticleCard
                article={article}
                path={article.type === '存档' ? 'archives' : 'articles'}
              />
            ))}
          </ul>
        </section>
      )
    }
  </Main>
</Layout>
