---
import Footer from '@components/layout/Footer.astro'
import Header from '@components/layout/Header.astro'
import Main from '@components/layout/Main.astro'
import Root from '@components/ui/Root.astro'

const error = {
  code: 'Todo',
  text: '越过长城',
  warning: ['「越过长城」正在开发中', 'This page is under development'],
}
---

<Root
  name="越过长城"
  description="Across the Great Wall we can reach every corner of the world."
  color="#40d583"
  favicon="/server/favicon.svg"
>
  <Header shortcut="Hello" />
  <Main error={error} />
  <Footer />
</Root>
