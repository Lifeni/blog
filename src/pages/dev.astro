---
import Footer from '@components/layout/Footer.astro'
import Header from '@components/layout/Header.astro'
import Main from '@components/layout/Main.astro'
import Root from '@components/ui/Root.astro'

const error = {
  code: 'Todo',
  text: '代码可行',
  warning: ['「代码可行」正在开发中', 'This page is under development'],
}
---

<Root
  name="代码可行"
  description="这里有一些做过的开源项目。"
  color="#f75248"
  favicon="/dev/favicon.svg"
>
  <Header shortcut="GitHub" />
  <Main error={error} />
  <Footer />
</Root>
