---
import { Image } from 'astro:assets'

const props = Astro.props
---

<div class:list={['wrapper', 'flex', 'animate-fade-in']}>
  <Image
    src={props.src}
    alt={props.alt}
    title={props.alt}
    loading="lazy"
    layout="full-width"
    class:list={[
      'medium-zoom',
      'w-full h-auto',
      'text-sm text-neutral-500 dark:text-neutral-400 leading-12',
      'bg-neutral-100 dark:bg-neutral-900',
      'rounded-md',
      props.class,
    ]}
  />
</div>
