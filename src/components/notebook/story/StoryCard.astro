---
import Spacer from '@components/ui/Spacer.astro'
import { frontmatterFormat } from '@libs/utils'
import { Icon } from 'astro-icon/components'
import { Image } from 'astro:assets'
import { getCollection } from 'astro:content'
import dayjs from 'dayjs'
import type { Story } from 'src/content'
import 'dayjs/locale/zh-cn'
import relativeTime from 'dayjs/plugin/relativeTime'
import Divider from '@components/ui/Divider.astro'

dayjs.extend(relativeTime)
dayjs.locale('zh-cn')

interface Props {
  story: Story
}

const { story } = Astro.props

const articles = await getCollection('文章')
const archives = await getCollection('存档')

const storyArticles = articles
  .filter(article => story.articles?.includes(article.data.id))
  .map(article => article.data)

const storyArchives = archives
  .filter(archive => story.articles?.includes(archive.data.name))
  .map(archive => frontmatterFormat(archive.data))

const allArticles = [...storyArticles, ...storyArchives]
  .filter(article => import.meta.env.DEV || !article.draft)
  .sort((a, b) => dayjs(b.date.updated).unix() - dayjs(a.date.updated).unix())
---

<li class:list={['w-full', 'mb-4', 'list-none break-inside-avoid']}>
  <a
    href={`/stories/${story.id}`}
    class:list={[
      'relative z-1 hover:z-10',
      'w-full',
      'p-4',
      'flex flex-col gap-4',
      'text-neutral-950 dark:text-neutral-100',
      'bg-white dark:bg-neutral-850',
      'focus-visible:outline-yellow-500 dark:focus-visible:outline-yellow-400 focus-visible:outline-4 focus-visible:outline-offset-1',
      'no-underline',
      'rounded-2xl',
      'hover:shadow-2xl',
      'transition-all',
    ]}
  >
    <div class:list={['flex']}>
      <Image
        src={story.cover.path}
        alt={story.cover.description}
        title={story.cover.description}
        loading="lazy"
        layout="full-width"
        class:list={[
          'w-full h-auto',
          'text-sm text-neutral-100 dark:text-neutral-900 leading-12',
          'bg-neutral-100 dark:bg-neutral-900',
          'rounded-md',
          'aspect-3/2 sm:aspect-1/1',
          'object-cover',
          'animate-fade-in',
        ]}
      />
    </div>
    <section class:list={['flex flex-col gap-1']}>
      <div class:list={['w-full', 'flex items-center gap-2']}>
        <h2 class:list={['m-0', 'font-bold text-base']}>
          # {story.name}
        </h2>
        <Spacer />
        <code
          class:list={[
            'm-0 p-0',
            'text-base text-neutral-500 dark:text-neutral-400 font-sans',
            'break-all md:break-word',
            'truncate',
          ]}
        >
          ×{allArticles.length || 0}
        </code>
      </div>
      <span
        class:list={[
          'text-sm text-neutral-500 dark:text-neutral-400',
          'truncate',
        ]}
      >
        {story.description}
      </span>
    </section>

    {
      allArticles.length > 0 && (
        <Fragment>
          <Divider />
          <ul class:list={['flex flex-col gap-1.5', 'px-0.5', 'list-none']}>
            {allArticles.slice(0, 3).map(article => (
              <li
                class:list={['m-0 p-0', 'flex gap-2 items-center', 'text-sm']}
              >
                <span class:list={['whitespace-nowrap']}>{article.name}</span>
                {article.subtitle && (
                  <span
                    class:list={[
                      'text-neutral-500 dark:text-neutral-400',
                      'truncate',
                    ]}
                  >
                    {article.subtitle}
                  </span>
                )}
                <Spacer />
                <date
                  class:list={[
                    'text-neutral-500 dark:text-neutral-400',
                    'whitespace-nowrap',
                  ]}
                >
                  {dayjs(article.date.created).fromNow()}
                </date>
              </li>
            ))}
          </ul>
        </Fragment>
      )
    }
  </a>
</li>
